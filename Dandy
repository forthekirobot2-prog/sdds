local function selectPlatform(p)
    cfg.platform = p

    for _, ch in ipairs(selFrame:GetDescendants()) do
        if ch:IsA("TextLabel") or ch:IsA("TextButton") then
            TweenService:Create(ch, twM, {TextTransparency = 1}):Play()
            if ch:IsA("TextButton") then
                TweenService:Create(ch, twM,
                    {BackgroundTransparency = 1}):Play()
            end
        elseif ch:IsA("UIStroke") then
            TweenService:Create(ch, twM, {Transparency = 1}):Play()
        end
    end
    TweenService:Create(selFrame, twM, {BackgroundTransparency = 1}):Play()

    task.delay(0.25, function()
        selFrame.Visible = false

        if p == "pc" then
            mainFrame.Size = UDim2.new(0, 245, 0, pcH)
            bindSection.Visible = true
            scroll.CanvasSize = UDim2.new(0, 0, 0, 380)
        else
            mainFrame.Size = UDim2.new(0, 245, 0, mobH)
            bindSection.Visible = false
            scroll.CanvasSize = UDim2.new(0, 0, 0, 270)
            mobGroup.Visible = true
        end

        mainFrame.BackgroundTransparency = 1
        mainFrame.Visible = true
        TweenService:Create(mainFrame, twM,
            {BackgroundTransparency = 0}):Play()
    end)
end

pcBtnSel.MouseButton1Click:Connect(function() selectPlatform("pc") end)
