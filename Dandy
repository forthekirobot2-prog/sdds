local function updateAC()
    if state.killCount > 0 then
        acLbl.Text = "killed (" .. state.killCount .. ")"
        acLbl.TextColor3 = C.green
    else
        acLbl.Text = "basic mode"
        acLbl.TextColor3 = C.orange
    end
end

local function toggleStyle(btn, on, mobKey)
    if on then
        btn.Text = "ON"; btn.TextColor3 = C.green
        TweenService:Create(btn, twF, {BackgroundColor3 = C.btnOn}):Play()
        if mobKey and mobBtns[mobKey] then
            mobBtns[mobKey].TextColor3 = C.green
            TweenService:Create(mobBtns[mobKey], twF,
                {BackgroundColor3 = C.btnOn}):Play()
        end
    else
        btn.Text = "OFF"; btn.TextColor3 = C.red
        TweenService:Create(btn, twF, {BackgroundColor3 = C.btn}):Play()
        if mobKey and mobBtns[mobKey] then
            mobBtns[mobKey].TextColor3 = C.red
            TweenService:Create(mobBtns[mobKey], twF,
                {BackgroundColor3 = C.btn}):Play()
        end
    end
end

