local twF = TweenInfo.new(0.1, Enum.EasingStyle.Quad)
local twM = TweenInfo.new(0.2, Enum.EasingStyle.Quad)

local function mk(cls, props)
    local i = Instance.new(cls)
    for k, v in pairs(props) do
        if k ~= "Parent" then i[k] = v end
    end
    if props.Parent then i.Parent = props.Parent end
    return i
end

local function corner(p, r)
    mk("UICorner", {CornerRadius = UDim.new(0, r or 6), Parent = p})
end

local function stroke(p)
    mk("UIStroke", {Color = C.border, Thickness = 1, Parent = p})
end

local function addHover(btn)
    btn.MouseEnter:Connect(function()
        TweenService:Create(btn, twF, {BackgroundColor3 = C.hov}):Play()
    end)
    btn.MouseLeave:Connect(function()
        TweenService:Create(btn, twF, {BackgroundColor3 = C.btn}):Play()
    end)
end

local function makeDrag(frame, handle)
    handle = handle or frame
    local d, ds, sp
    handle.InputBegan:Connect(function(i)
        if state.sliderDragging then return end
        if i.UserInputType == Enum.UserInputType.MouseButton1
            or i.UserInputType == Enum.UserInputType.Touch then
            d = true; ds = i.Position; sp = frame.Position
            i.Changed:Connect(function()
                if i.UserInputState == Enum.UserInputState.End then
                    d = false
                end
            end)
        end
    end)
    UIS.InputChanged:Connect(function(i)
        if state.sliderDragging then d = false; return end
        if d and (i.UserInputType == Enum.UserInputType.MouseMovement
            or i.UserInputType == Enum.UserInputType.Touch) then
            local delta = i.Position - ds
            frame.Position = UDim2.new(
                sp.X.Scale, sp.X.Offset + delta.X,
                sp.Y.Scale, sp.Y.Offset + delta.Y
            )
        end
    end)
end

-- MOBILE DRAG: separate system for button group
-- Distinguishes tap (< 8px movement) from drag
local function makeMobDrag(frame, handle)
    local d, ds, sp, totalMove

    handle.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.Touch
            or i.UserInputType == Enum.UserInputType.MouseButton1 then
            d = true
            ds = i.Position
            sp = frame.Position
            totalMove = 0
            state.mobDragging = false

            i.Changed:Connect(function()
                if i.UserInputState == Enum.UserInputState.End then
                    d = false
                    task.delay(0.05, function()
                        state.mobDragging = false
                    end)
                end
            end)
        end
    end)

    UIS.InputChanged:Connect(function(i)
        if d and (i.UserInputType == Enum.UserInputType.Touch
            or i.UserInputType == Enum.UserInputType.MouseMovement) then
            local delta = i.Position - ds
            totalMove = totalMove + delta.Magnitude

            -- Only drag if moved more than 8 pixels
            if totalMove > 8 then
                state.mobDragging = true
                frame.Position = UDim2.new(
                    sp.X.Scale, sp.X.Offset + delta.X,
                    sp.Y.Scale, sp.Y.Offset + delta.Y
                )
            end
        end
    end)
end

local function createSlider(parent, pos, minVal, maxVal, default, onChange)
    local frame = mk("Frame", {
        Size = UDim2.new(1, -16, 0, 36),
        Position = pos,
        BackgroundTransparency = 1,
        Parent = parent,
    })

    local valLabel = mk("TextLabel", {
        Size = UDim2.new(0, 40, 0, 16),
        Position = UDim2.new(1, -40, 0, 0),
        BackgroundTransparency = 1,
        Text = tostring(default),
        TextColor3 = C.text, TextSize = 11,
        Font = Enum.Font.GothamBold,
        TextXAlignment = Enum.TextXAlignment.Right,
        Parent = frame,
    })

    mk("TextLabel", {
        Size = UDim2.new(1, -48, 0, 16),
        Position = UDim2.new(0, 0, 0, 0),
        BackgroundTransparency = 1,
        Text = "Speed: " .. minVal .. " - " .. maxVal,
        TextColor3 = C.dim, TextSize = 9,
        Font = Enum.Font.Gotham,
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = frame,
    })

    local track = mk("Frame", {
        Size = UDim2.new(1, 0, 0, 8),
        Position = UDim2.new(0, 0, 0, 22),
        BackgroundColor3 = C.slider,
        BorderSizePixel = 0,
        Parent = frame,
    })
    corner(track, 4)

    local initF = (default - minVal) / (maxVal - minVal)

    local fill = mk("Frame", {
        Size = UDim2.new(initF, 0, 1, 0),
        BackgroundColor3 = C.sFill,
        BorderSizePixel = 0,
        Parent = track,
    })
    corner(fill, 4)

    local knob = mk("Frame", {
        Size = UDim2.new(0, 16, 0, 16),
        Position = UDim2.new(initF, -8, 0.5, -8),
        BackgroundColor3 = C.knob,
        BorderSizePixel = 0,
        ZIndex = 5,
        Parent = track,
    })
    corner(knob, 8)

    local safeP = (40 - minVal) / (maxVal - minVal)
    mk("Frame", {
        Size = UDim2.new(0, 2, 1, 6),
        Position = UDim2.new(safeP, -1, 0, -3),
        BackgroundColor3 = C.red,
        BorderSizePixel = 0,
        ZIndex = 4,
        Parent = track,
    })

    local function updateS(inputPos)
        local tA = track.AbsolutePosition
        local tS = track.AbsoluteSize
        local rel = clamp((inputPos.X - tA.X) / tS.X, 0, 1)
        local val = math.floor(lerp(minVal, maxVal, rel))

        fill.Size = UDim2.new(rel, 0, 1, 0)
        knob.Position = UDim2.new(rel, -8, 0.5, -8)
        valLabel.Text = tostring(val)

        if val <= 40 then
            fill.BackgroundColor3 = C.green
            valLabel.TextColor3 = C.green
        elseif val <= 100 then
            fill.BackgroundColor3 = C.sFill
            valLabel.TextColor3 = C.text
        elseif val <= 200 then
            fill.BackgroundColor3 = C.orange
            valLabel.TextColor3 = C.orange
        else
            fill.BackgroundColor3 = C.red
            valLabel.TextColor3 = C.red
        end

        if onChange then onChange(val) end
    end

    track.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1
            or i.UserInputType == Enum.UserInputType.Touch then
            state.sliderDragging = true
            updateS(i.Position)
        end
    end)

    knob.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1
            or i.UserInputType == Enum.UserInputType.Touch then
            state.sliderDragging = true
        end
    end)

    UIS.InputChanged:Connect(function(i)
        if state.sliderDragging and (
            i.UserInputType == Enum.UserInputType.MouseMovement
            or i.UserInputType == Enum.UserInputType.Touch
        ) then
            updateS(i.Position)
        end
    end)

    UIS.InputEnded:Connect(function(i)
