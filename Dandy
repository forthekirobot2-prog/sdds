local compat = {
    hasGC = pcall(function() return getconnections end)
        and type(getconnections) == "function",
    hasHM = pcall(function() return hookmetamethod end)
        and type(hookmetamethod) == "function",
    hasGN = pcall(function() return getnamecallmethod end)
        and type(getnamecallmethod) == "function",
    hasNC = pcall(function() return newcclosure end)
        and type(newcclosure) == "function",
}

local function safeWrap(fn)
    if compat.hasNC then return newcclosure(fn) end
    return fn
end

local cfg = {
    platform = nil,
    binds = {
        walltp = Enum.KeyCode.V,
        fly = Enum.KeyCode.G,
        speed = Enum.KeyCode.X,
