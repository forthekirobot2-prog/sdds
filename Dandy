    maxSafeWS = 38,
    maxWallThick = 25,
    tpOffset = 2.5,
    cooldown = 0.3,
}

local state = {
    conns = {},
    keys = {},
    acKilled = false,
    killCount = 0,
    lastTP = 0,
    origWS = 16,
    origJP = 50,
    origJH = 0,
    sliderDragging = false,
    mobDragging = false,
    origLighting = {},
    disabledEffects = {},
}

local function getChar() return player.Character end
local function getHRP()
    local c = getChar()
    return c and c:FindFirstChild("HumanoidRootPart")
end
local function getHum()
    local c = getChar()
    return c and c:FindFirstChildOfClass("Humanoid")
end
local function clamp(v, mn, mx)
    return math.max(mn, math.min(mx, v))
end
local function lerp(a, b, t) return a + (b - a) * t end

-- ===================================
-- AC KILLER
-- ===================================

local function killACListeners()
    if not compat.hasGC then return 0 end
    local char = getChar()
    if not char then return 0 end
    local killed = 0

    for _, part in ipairs(char:GetDescendants()) do
        if part:IsA("BasePart") then
            for _, prop in ipairs({
                "CanCollide","Size","Velocity",
                "CFrame","Position","Transparency"
            }) do
                pcall(function()
                    for _, c in ipairs(
                        getconnections(
                            part:GetPropertyChangedSignal(prop)
                        )
                    ) do
                        c:Disable(); killed = killed + 1
                    end
                end)
            end
            pcall(function()
                for _, c in ipairs(getconnections(part.Changed)) do
                    c:Disable(); killed = killed + 1
                end
            end)
        end
    end

    local hum = getHum()
    if hum then
        for _, prop in ipairs({
            "WalkSpeed","JumpPower","JumpHeight",
            "Health","HipHeight"
        }) do
            pcall(function()
                for _, c in ipairs(
                    getconnections(
                        hum:GetPropertyChangedSignal(prop)
                    )
                ) do
                    c:Disable(); killed = killed + 1
                end
            end)
        end
        pcall(function()
            for _, c in ipairs(getconnections(hum.Changed)) do
                c:Disable(); killed = killed + 1
            end
        end)
        pcall(function()
            for _, c in ipairs(getconnections(hum.StateChanged)) do
                c:Disable(); killed = killed + 1
            end
        end)
    end

    for _, ev in ipairs({"ChildAdded","DescendantAdded","ChildRemoved"}) do
        pcall(function()
            for _, c in ipairs(getconnections(char[ev])) do
                c:Disable(); killed = killed + 1
            end
        end)
    end

    return killed
end

local function killRemoteListeners()
    if not compat.hasGC then return 0 end
    local killed = 0
    pcall(function()
        for _, r in ipairs(
            game:GetService("ReplicatedStorage"):GetDescendants()
        ) do
            if r:IsA("RemoteEvent") or r:IsA("RemoteFunction") then
                local n = r.Name:lower()
                if n:find("anti") or n:find("cheat")
                    or n:find("detect") or n:find("kick")
                    or n:find("ban") or n:find("valid")
                    or n:find("check") or n:find("verify")
                    or n:find("security") or n:find("flag") then
                    if r:IsA("RemoteEvent") then
                        pcall(function()
                            for _, c in ipairs(
                                getconnections(r.OnClientEvent)
                            ) do
                                c:Disable(); killed = killed + 1
                            end
                        end)
                    end
                end
            end
        end
    end)
    return killed
end

local function hookACRemotes()
    if not compat.hasHM or not compat.hasGN then return end
    pcall(function()
        local old
        old = hookmetamethod(game, "__namecall",
            safeWrap(function(self, ...)
                local m = getnamecallmethod()
                if m == "FireServer" or m == "InvokeServer" then
                    if self:IsA("RemoteEvent")
                        or self:IsA("RemoteFunction") then
                        local n = self.Name:lower()
                        if n:find("anti") or n:find("cheat")
                            or n:find("detect") or n:find("kick")
                            or n:find("ban") or n:find("valid")
                            or n:find("check") or n:find("verify")
                            or n:find("security") or n:find("flag") then
                            return nil
                        end
                    end
                end
                return old(self, ...)
            end)
        )
    end)
end

local function runACKill()
    if state.acKilled then return end
    local k1 = killACListeners()
    local k2 = killRemoteListeners()
    hookACRemotes()
    state.killCount = k1 + k2
    state.acKilled = true
end

-- ===================================
-- WALL TP
-- ===================================

local function getMoveDirection()
    local hum = getHum()
    if hum and hum.MoveDirection.Magnitude > 0.1 then
        return hum.MoveDirection.Unit
    end
    local look = camera.CFrame.LookVector
    return Vector3.new(look.X, 0, look.Z).Unit
end

local function wallTP()
    local hrp = getHRP()
    local char = getChar()
    if not hrp or not char then return false end
    if tick() - state.lastTP < cfg.cooldown then return false end

    local dir = getMoveDirection()
    if not dir then return false end

    local rp = RaycastParams.new()
    rp.FilterDescendantsInstances = {char}
    rp.FilterType = Enum.RaycastFilterType.Exclude

    local origin = hrp.Position
    local fwdHit = WS:Raycast(origin, dir * cfg.maxWallThick, rp)
    if not fwdHit then return false end

    local backOrigin = origin + dir * cfg.maxWallThick
    local backHit = WS:Raycast(backOrigin, -dir * cfg.maxWallThick, rp)

    local target
    if backHit then
        target = backHit.Position + dir * cfg.tpOffset
    else
        local dist = (fwdHit.Position - origin).Magnitude
        target = origin + dir * (dist + 6)
    end
    target = Vector3.new(target.X, origin.Y, target.Z)

    local floorHit = WS:Raycast(
        target + Vector3.new(0, 5, 0),
        Vector3.new(0, -50, 0), rp
    )
    if floorHit then
        target = Vector3.new(target.X, floorHit.Position.Y + 3, target.Z)
    end

    local _, ry, _ = hrp.CFrame:ToEulerAnglesYXZ()
    hrp.CFrame = CFrame.new(target) * CFrame.Angles(0, ry, 0)
    hrp.Velocity = Vector3.new(0, 0, 0)
    pcall(function()
        hrp.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
    end)

    state.lastTP = tick()
    return true
end

-- ===================================
-- FLY
-- ===================================

local function startFly()
    local hum = getHum()
    if not hum then return end
    state.origWS = hum.WalkSpeed
    state.origJP = hum.JumpPower
    state.origJH = hum.JumpHeight

    state.conns.fly = RunService.Stepped:Connect(function(_, dt)
        local hrp = getHRP()
        local hum2 = getHum()
        local char = getChar()
        if not hrp or not hum2 or not char then return end

        for _, p in ipairs(char:GetDescendants()) do
            if p:IsA("BasePart") then p.CanCollide = false end
        end

        hum2.WalkSpeed = 0
        hum2.JumpPower = 0
        hum2.JumpHeight = 0

        local camCF = camera.CFrame
        local md = hum2.MoveDirection
        local vel = Vector3.new(0,0,0)

        if md.Magnitude > 0.1 then
            local cL = camCF.LookVector
            local cR = camCF.RightVector
            local fwd = Vector3.new(cL.X,0,cL.Z).Unit
            local rgt = Vector3.new(cR.X,0,cR.Z).Unit
            vel = (fwd * md:Dot(fwd) + rgt * md:Dot(rgt)).Unit * cfg.flySpeed
        end

        local vy = 0
        if state.keys[Enum.KeyCode.Space] or state.keys["up"] then
            vy = cfg.flyVSpeed
        elseif state.keys[Enum.KeyCode.LeftShift]
            or state.keys[Enum.KeyCode.LeftControl]
            or state.keys["down"] then
            vy = -cfg.flyVSpeed
        end

        local mv = vel * dt
        hrp.CFrame = hrp.CFrame + Vector3.new(mv.X, vy * dt, mv.Z)
        hrp.Velocity = Vector3.new(0,0,0)
        pcall(function()
            hrp.AssemblyLinearVelocity = Vector3.new(0,0,0)
        end)
        hum2:ChangeState(Enum.HumanoidStateType.Running)
    end)
end

local function stopFly()
    if state.conns.fly then
        state.conns.fly:Disconnect()
        state.conns.fly = nil
    end
    local hum = getHum()
    if hum then
        hum.WalkSpeed = state.origWS or 16
        hum.JumpPower = state.origJP or 50
        hum.JumpHeight = state.origJH or 0
    end
    local char = getChar()
    if char then
        for _, p in ipairs(char:GetDescendants()) do
            if p:IsA("BasePart") then p.CanCollide = true end
        end
    end
    local hrp = getHRP()
    if hrp and char then
        local rp = RaycastParams.new()
        rp.FilterDescendantsInstances = {char}
        rp.FilterType = Enum.RaycastFilterType.Exclude
        local hit = WS:Raycast(hrp.Position, Vector3.new(0,-500,0), rp)
        if hit then
            local _, ry, _ = hrp.CFrame:ToEulerAnglesYXZ()
            hrp.CFrame = CFrame.new(hit.Position + Vector3.new(0,3,0))
                * CFrame.Angles(0, ry, 0)
        end
        hrp.Velocity = Vector3.new(0,0,0)
        pcall(function()
            hrp.AssemblyLinearVelocity = Vector3.new(0,0,0)
        end)
    end
    state.keys = {}
end

-- ===================================
-- SPEEDHACK
-- ===================================

local function startSpeed()
    local hum = getHum()
    if not hum then return end
    state.origWS = hum.WalkSpeed

    state.conns.speed = RunService.Stepped:Connect(function(_, dt)
        local hrp = getHRP()
        local hum2 = getHum()
        if not hrp or not hum2 then return end

        local target = cfg.speedValue
        if target <= cfg.maxSafeWS then
            hum2.WalkSpeed = target
            return
        end

        hum2.WalkSpeed = cfg.maxSafeWS
        local md = hum2.MoveDirection
        if md.Magnitude < 0.1 then return end

        local extra = target - cfg.maxSafeWS
        local nudge = md.Unit * extra * dt
        hrp.CFrame = hrp.CFrame + Vector3.new(nudge.X, 0, nudge.Z)
    end)
end

local function stopSpeed()
    if state.conns.speed then
        state.conns.speed:Disconnect()
        state.conns.speed = nil
    end
    local hum = getHum()
    if hum then hum.WalkSpeed = state.origWS or 16 end
end

-- ===================================
-- FULLBRIGHT
-- ===================================

local function startFullbright()
    state.origLighting = {
        Brightness = Lighting.Brightness,
        ClockTime = Lighting.ClockTime,
        FogEnd = Lighting.FogEnd,
        GlobalShadows = Lighting.GlobalShadows,
        Ambient = Lighting.Ambient,
        OutdoorAmbient = Lighting.OutdoorAmbient,
    }

    Lighting.Brightness = 2
    Lighting.ClockTime = 14
    Lighting.FogEnd = 100000
    Lighting.GlobalShadows = false
    Lighting.Ambient = Color3.fromRGB(178, 178, 178)
    Lighting.OutdoorAmbient = Color3.fromRGB(178, 178, 178)

    state.disabledEffects = {}
    for _, effect in ipairs(Lighting:GetChildren()) do
        if effect:IsA("ColorCorrectionEffect")
            or effect:IsA("BloomEffect")
            or effect:IsA("BlurEffect")
            or effect:IsA("DepthOfFieldEffect")
            or effect:IsA("SunRaysEffect") then
            if effect.Enabled then
                effect.Enabled = false
                table.insert(state.disabledEffects, effect)
            end
        end
    end
end

local function stopFullbright()
    if state.origLighting.Brightness then
        Lighting.Brightness = state.origLighting.Brightness
        Lighting.ClockTime = state.origLighting.ClockTime
        Lighting.FogEnd = state.origLighting.FogEnd
        Lighting.GlobalShadows = state.origLighting.GlobalShadows
        Lighting.Ambient = state.origLighting.Ambient
        Lighting.OutdoorAmbient = state.origLighting.OutdoorAmbient
    end
    for _, e in ipairs(state.disabledEffects) do
        pcall(function() e.Enabled = true end)
    end
    state.disabledEffects = {}
end

-- ===================================
-- RESPAWN
-- ===================================

player.CharacterAdded:Connect(function(char)
    char:WaitForChild("HumanoidRootPart")
    char:WaitForChild("Humanoid")
    task.wait(2)
    state.acKilled = false
    runACKill()
    if cfg.flyActive then stopFly(); cfg.flyActive = true; startFly() end
    if cfg.speedActive then
        stopSpeed(); cfg.speedActive = true; startSpeed()
    end
    if cfg.fullbrightActive then startFullbright() end
end)

