local inputConns = {}

inputConns[1] = UIS.InputBegan:Connect(function(input, gpe)
    if input.UserInputType ~= Enum.UserInputType.Keyboard then return end

    if cfg.listening then
        cfg.binds[cfg.listening] = input.KeyCode
        cfg.listening = nil
        if _G._ImkoBindUpdate then _G._ImkoBindUpdate() end
        return
    end

    if cfg.flyActive then
        if input.KeyCode == Enum.KeyCode.Space
            or input.KeyCode == Enum.KeyCode.LeftShift
            or input.KeyCode == Enum.KeyCode.LeftControl then
            state.keys[input.KeyCode] = true
        end
    end

    if gpe then return end
    state.keys[input.KeyCode] = true

    if cfg.platform == "pc" then
        if input.KeyCode == cfg.binds.walltp then
            runACKill()
            local ok = wallTP()
            if _G._ImkoWallStatus then _G._ImkoWallStatus(ok) end
        end
        if input.KeyCode == cfg.binds.fly then
            runACKill()
            cfg.flyActive = not cfg.flyActive
            if cfg.flyActive then startFly() else stopFly() end
            if _G._ImkoFlyUpdate then _G._ImkoFlyUpdate(cfg.flyActive) end
        end
        if input.KeyCode == cfg.binds.speed then
            runACKill()
            cfg.speedActive = not cfg.speedActive
            if cfg.speedActive then startSpeed() else stopSpeed() end
            if _G._ImkoSpeedUpdate then
                _G._ImkoSpeedUpdate(cfg.speedActive)
            end
        end
    end
end)

inputConns[2] = UIS.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.Keyboard then
        state.keys[input.KeyCode] = nil
    end
end)

